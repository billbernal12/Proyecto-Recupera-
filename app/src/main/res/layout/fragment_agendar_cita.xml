<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Título principal -->
        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agendar cita para:"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <!-- Nombre del usuario (Firebase) -->
        <TextView
            android:id="@+id/tvNombreUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cargando usuario..."
            android:textSize="18sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="24dp" />

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/tvDatosCita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Datos de la cita médica"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="4dp" />

        <!-- Línea decorativa -->
        <View
            android:layout_width="80dp"
            android:layout_height="2dp"
            android:background="@android:color/darker_gray"
            android:layout_marginBottom="16dp" />

        <!-- Selección de especialista -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona especialista:"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <!-- Spinner fondo blanco -->
        <Spinner
            android:id="@+id/spinnerEspecialistas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:layout_marginBottom="24dp"
            android:padding="8dp"
            android:popupBackground="@android:color/white" />

        <!-- Descripción de la situación -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Describe tu situación:"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <!-- Cuadro de texto fondo blanco -->
        <EditText
            android:id="@+id/etDescripcion"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Máx. 50 palabras..."
            android:gravity="top|start"
            android:background="@android:color/white"
            android:padding="12dp"
            android:elevation="2dp"
            android:maxLength="300"
            android:inputType="textMultiLine"
            android:layout_marginBottom="4dp" />

        <!-- Contador de palabras -->
        <TextView
            android:id="@+id/tvContadorPalabras"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 50 palabras"
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- Botón reservar -->
        <Button
            android:id="@+id/btnReservarCita"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reservar cita"
            android:textColor="@android:color/white"
            android:backgroundTint="@android:color/black"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:layout_marginHorizontal="32dp" />

    </LinearLayout>
</ScrollView>
